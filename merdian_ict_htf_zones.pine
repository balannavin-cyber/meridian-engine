    draw_zone(73965.12, 74048.61, c_bull_fvg_t1, c_bull_fvg_t1_l, "M5 BULL_FVG jun-02 (WR 50%)", 13, false, show_fvg and show_h)
    if show_positioning
        var box   pos_pin_bx = na
        var label pos_pin_lb = na
        box.delete(pos_pin_bx)
        label.delete(pos_pin_lb)
        pos_pin_bx := box.new(bar_index - 30, 77700.00, bar_index + 50, 77400.00, bgcolor=c_pin_zone, border_color=c_pin_line, border_width=1, extend=extend.right)
        pos_pin_lb := label.new(bar_index + 90, 77700.00, text="PIN 77400-77700 (peak 77600, +38K Cr)", color=color.new(color.black, 100), textcolor=c_pin_line, style=label.style_label_lower_left, size=size.small)
        var box   pos_accel_bx = na
        var label pos_accel_lb = na
        box.delete(pos_accel_bx)
        label.delete(pos_accel_lb)
        pos_accel_bx := box.new(bar_index - 30, 76076.00, bar_index + 50, 75924.00, bgcolor=c_accel_zone, border_color=c_accel_line, border_width=1, extend=extend.right)
        pos_accel_lb := label.new(bar_index + 90, 75924.00, text="ACCEL 76000 (single strike, -26K Cr)", color=color.new(color.black, 100), textcolor=c_accel_line, style=label.style_label_upper_left, size=size.small)

// ── HEADER ───────────────────────────────────────────────────────────────────
if barstate.islast
    var label hdr = na
    label.delete(hdr)
    sym_str = is_nifty ? "NIFTY" : (is_sensex ? "SENSEX" : "OTHER")
    n_zones = is_nifty ? 34 : (is_sensex ? 45 : 0)
    hdr := label.new(x=bar_index, y=high * 1.001, text="MERDIAN HTF | " + sym_str + " | " + str.tostring(n_zones) + " zones | entry-band | 2026-06-19", color=color.new(color.black, 80), textcolor=color.white, style=label.style_label_down, size=size.small)
