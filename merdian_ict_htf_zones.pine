// ── HEADER ───────────────────────────────────────────────────────────────────
if barstate.islast
    var label hdr = na
    label.delete(hdr)
    sym_str = is_nifty ? "NIFTY" : (is_sensex ? "SENSEX" : "OTHER")
    n_zones = is_nifty ? 24 : (is_sensex ? 30 : 0)
    hdr := label.new(x=bar_index, y=high * 1.001, text="MERDIAN HTF | " + sym_str + " | " + str.tostring(n_zones) + " zones | entry-band | 2026-05-03", color=color.new(color.black, 80), textcolor=color.white, style=label.style_label_down, size=size.small)
