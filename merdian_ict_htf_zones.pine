c_pdl_d_t1_l    = color.new(color.yellow,  8)
c_pdh_w_t1_l    = color.new(color.orange, 18)
c_pdl_w_t1_l    = color.new(color.orange, 18)

// ── T2: medium opacity (W zones 2-5% from spot) ──────────────────────────────
