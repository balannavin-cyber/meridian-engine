c_pdl_w_t2_l    = color.new(color.orange, 52)

// ── T3: ghost (>5% from spot, no labels) ─────────────────────────────────────
c_bull_ob_t3    = color.new(#1B8C3E,  93)
c_bull_fvg_t3   = color.new(#7EC85A,  93)
