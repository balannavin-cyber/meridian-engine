    hdr := label.new(x=bar_index, y=high * 1.001, text="MERDIAN HTF | " + sym_str + " | " + str.tostring(n_zones) + " zones | entry-band | 2026-05-27", color=color.new(color.black, 80), textcolor=color.white, style=label.style_label_down, size=size.small)
